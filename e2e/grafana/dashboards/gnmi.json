{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["gnmi", "prometheus", "telemetry"],
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "title": "gNMI Telemetry (live)",
  "uid": "gnmi-telemetry",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Interface throughput (bits/sec)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prom-gnmi" },
      "description": "Scraped from the gnmi.telemetry exporter. Per-interface in/out rate computed at the source (gnmi_in_octets_bps, gnmi_out_octets_bps).",
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "spanNulls": true, "showPoints": "never", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prom-gnmi" },
          "expr": "gnmi_in_octets_bps",
          "legendFormat": "{{target}} {{interface}} in"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prom-gnmi" },
          "expr": "gnmi_out_octets_bps",
          "legendFormat": "{{target}} {{interface}} out"
        }
      ]
    },
    {
      "id": 2,
      "title": "Interface oper/admin status (1 = up)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prom-gnmi" },
      "description": "oper_status / admin_status mapped to 1 (UP) / 0 (other) at the source.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "spanNulls": true, "showPoints": "always", "fillOpacity": 20 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prom-gnmi" },
          "expr": "gnmi_oper_status",
          "legendFormat": "{{target}} {{interface}} oper"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prom-gnmi" },
          "expr": "gnmi_admin_status",
          "legendFormat": "{{target}} {{interface}} admin"
        }
      ]
    }
  ]
}
